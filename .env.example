# LLM Provider Configuration (choose one)
# Options: anthropic, gemini, openai
LLM_PROVIDER=anthropic

# LLM Generation Parameters
LLM_MAX_TOKENS=4096

# Anthropic API Key (if using Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (API key from https://aistudio.google.com/apikey uses free tier, not GCP billing)
# For GCP $300 credit use Vertex AI instead of this key. Prefer gemini-1.5-flash for free tier.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API Key (if using OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# FakeStoreAPI Configuration
FAKE_STORE_BASE_URL=https://fakestoreapi.com
FAKE_STORE_TIMEOUT=15.0

# Database Configuration
DATABASE_URL=sqlite:///./shopping_assistant.db

# Conversation persistence (optional; per-session history in Redis)
# Leave empty for in-memory storage. Example: redis://localhost:6379/0
REDIS_URL=
CONVERSATION_TTL_SECONDS=86400

# Vector Database Configuration
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_db

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Backend
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth (for frontend authentication)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Backend JWT (for /auth/login and cart persistence; can match NEXTAUTH_SECRET)
JWT_SECRET=your-jwt-secret-here
